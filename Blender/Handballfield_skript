# ---------- Curve Helper ----------
def create_curve(points):

    curve=bpy.data.curves.new("curve","CURVE")
    curve.dimensions='3D'

    spline=curve.splines.new('POLY')
    spline.points.add(len(points)-1)

    for i,p in enumerate(points):
        spline.points[i].co=(p[0],p[1],0,1)

    obj=bpy.data.objects.new("curve_obj",curve)
    bpy.context.collection.objects.link(obj)

    curve.bevel_depth=LINE_W/2
    curve.bevel_resolution=4

    obj.data.materials.clear()
    obj.data.materials.append(line_mat)

    return obj


# ---------- Arc Punkte ----------
def arc_points(cx,cy,r,a0,a1,steps=64):

    pts=[]

    for i in range(steps+1):
        a=a0+(a1-a0)*i/steps
        x=cx+r*math.cos(a)
        y=cy+r*math.sin(a)
        pts.append((x,y))

    return pts


# ---------- 6m Linie ----------
pts=[]
pts+=arc_points(-20,-1.5,R6,-math.pi/2,0)
pts.append((-14,-1.5))
pts.append((-14,1.5))
pts+=arc_points(-20,1.5,R6,0,math.pi/2)

create_curve(pts)

pts=[]
pts+=arc_points(20,1.5,R6,math.pi/2,math.pi)
pts.append((14,1.5))
pts.append((14,-1.5))
pts+=arc_points(20,-1.5,R6,math.pi,3*math.pi/2)

create_curve(pts)


# ---------- gestrichelter Arc ----------
def dashed_arc(cx,cy,r,a0,a1):

    a=a0

    while a<a1:

        seg=DASH_LEN/r
        mid=a+seg/2

        x=cx+r*math.cos(mid)
        y=cy+r*math.sin(mid)

        rot=mid+math.pi/2

        rect(DASH_LEN,LINE_W,x,y,rot)

        a+=(DASH_LEN+DASH_GAP)/r


# ---------- 9m Linie ----------
dashed_arc(-20,-1.5,R9,-math.pi/2,0)
dashed_arc(-20,1.5,R9,0,math.pi/2)

dashed_arc(20,1.5,R9,math.pi/2,math.pi)
dashed_arc(20,-1.5,R9,math.pi,3*math.pi/2)


# ---------- gestrichelte Verbindung ----------
def dashed_line(x):

    y=-1.5

    while y<1.5:

        rect(DASH_LEN,LINE_W,x,y+DASH_LEN/2,math.pi/2)

        y+=DASH_LEN+DASH_GAP


dashed_line(-11)
dashed_line(11)


