import bpy
import math

# ---------- Parameter ----------
FIELD_LENGTH = 40
FIELD_WIDTH = 20

LINE_W = 0.05

R6 = 6
R9 = 9

GOAL_HALF = 1.5

DASH_LEN = 0.15
DASH_GAP = 0.15


# ---------- Szene leeren ----------
bpy.ops.object.select_all(action='SELECT')
bpy.ops.object.delete(use_global=False)


# ---------- Materialien ----------
def create_material(name,color):
    mat=bpy.data.materials.new(name)
    mat.use_nodes=True
    bsdf=mat.node_tree.nodes["Principled BSDF"]
    bsdf.inputs[0].default_value=(color[0],color[1],color[2],1)
    return mat

field_mat=create_material("Field",(0.6,0.85,1))
line_mat=create_material("Line",(1,1,1))  # reines Weiß


# ---------- Rechteck ----------
def rect(xlen,ylen,x,y,rot=0):
    bpy.ops.mesh.primitive_plane_add(size=1,location=(x,y,0.002),rotation=(0,0,rot))
    o=bpy.context.object
    o.dimensions=(xlen,ylen,0)

    o.data.materials.clear()
    o.data.materials.append(line_mat)

    return o


